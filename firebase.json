{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "namsung-meeting-room-7811f",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "DEPLOY.md",
      "firestore.rules",
      "mrs_ns_test.html",
      "mrs_ns_en.html",
      "mrs_ns_v*.html"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/mrs_ns.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(webmanifest|svg|png)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/mrs_ns.html"
      }
    ]
  }
}
